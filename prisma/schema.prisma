generator client {
  provider        = "prisma-client"
  output          = "generated"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Role {
  ADMIN
  TECHNICIAN
  CLIENT
}

enum Status {
  OPEN
  IN_PROGRESS
  CLOSED
}

model User {
  id                 String                   @id @default(uuid())
  name               String
  email              String                   @unique
  password           String
  role               Role
  profileImageUrl    String?
  mustChangePassword Boolean                  @default(false)
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime?                @map("updated_at")
  availabilities     TechnicianAvailability[]

  clientTickets     Ticket[] @relation("ClientTickets")
  technicianTickets Ticket[] @relation("TechnicianTickets")

  @@map("users")
}

model TechnicianAvailability {
  id           String  @id @default(uuid())
  technicianId String
  weekDay      WeekDay
  startTime    String
  endTime      String

  technician User @relation(fields: [technicianId], references: [id])

  @@index([technicianId])
  @@map("technician_availabilities")
}

model Service {
  id             String          @id @default(uuid())
  name           String
  description    String?
  priceInCents   Int
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime?       @map("updated_at")
  ticketServices TicketService[]

  @@map("services")
}

model Ticket {
  id           String @id @default(uuid())
  clientId     String
  technicianId String
  status       Status

  client     User @relation("ClientTickets", fields: [clientId], references: [id])
  technician User @relation("TechnicianTickets", fields: [technicianId], references: [id])

  services TicketService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tickets")
}

model TicketService {
  id String @id @default(uuid())

  ticketId  String
  serviceId String

  ticket  Ticket  @relation(fields: [ticketId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  priceInCents Int

  @@map("ticket_services")
}
