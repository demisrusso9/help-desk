generator client {
  provider        = "prisma-client"
  output          = "generated"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TECHNICIAN
  CLIENT
}

enum Status {
  OPEN
  IN_PROGRESS
  CLOSED
}

model User {
  id                 String    @id @default(uuid())
  name               String
  email              String    @unique
  password           String
  role               Role
  profileImageUrl    String?
  mustChangePassword Boolean   @default(false)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime? @map("updated_at")

  clientTickets     Ticket[] @relation("ClientTickets")
  technicianTickets Ticket[] @relation("TechnicianTickets")

  @@map("users")
}

model Service {
  id             String          @id @default(uuid())
  name           String
  description    String?
  priceInCents   Int
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ticketServices TicketService[]

  @@map("services")
}

model Ticket {
  id           String @id @default(uuid())
  clientId     String
  technicianId String
  status       Status

  client     User @relation("ClientTickets", fields: [clientId], references: [id])
  technician User @relation("TechnicianTickets", fields: [technicianId], references: [id])

  services TicketService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketService {
  id String @id @default(uuid())

  ticketId  String
  serviceId String

  ticket  Ticket  @relation(fields: [ticketId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  priceInCents Int
}
